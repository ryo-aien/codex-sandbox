# Copy this file to .env and adjust values as needed.

# Host user/group IDs to keep file ownership aligned between host and container.
HOST_UID=1000
HOST_GID=1000

# ホスト側のプロジェクトルートをコンテナの /workspace にマウントするディレクトリ。
CODEX_WORKSPACE_DIR=./

# Codex をインストールするコマンド（例: npm install -g @openai/codex）。イメージのビルド時に
# install-codex が自動実行される際にもこの値が使われます。
CODEX_INSTALL_CMD="npm install -g @openai/codex"

# ホストに保存された auth.json をコンテナへマウントする場合の絶対パス。
# docker-compose.yml で ${HOME} を使っているため、通常は不要です。
# CODEX_AUTH_FILE=/Users/yourname/.codex/auth.json
